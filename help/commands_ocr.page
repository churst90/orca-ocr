    <title type="sort">2. OCR</title>
    <title type="link">OCR</title>
    <desc>
      Commands for recognizing and acting on the text in any window
    </desc>
    <credit type="author">
      <name>Cody Hurst</name>
      <email>codythurst@gmail.com</email>
